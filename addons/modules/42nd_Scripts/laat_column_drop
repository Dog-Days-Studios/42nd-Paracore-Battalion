/*
    Column airdrop for 42nd LAAT variants.
    Attached via Extended_InitPost_EventHandlers in addons/main/config.cpp.
*/

params [["_laat", objNull, [objNull]]];
if (isNull _laat) exitWith {};

if (isNil "para42_fnc_laatNotify") then {
    para42_fnc_laatNotify = {
        params ["_unit", "_message"];
        if (isNull _unit) exitWith {};
        [_message] remoteExecCall ["hint", owner _unit];
    };
};

if (isNil "para42_fnc_storeBackpackState") then {
    para42_fnc_storeBackpackState = {
        params [["_unit", objNull, [objNull]]];
        if (isNull _unit) exitWith {};

        private _backpackClass = backpack _unit;
        private _itemCargo = [[], []];
        private _magazineCargo = [[], []];
        private _weaponCargo = [[], []];
        private _backpackCargo = [[], []];

        private _container = backpackContainer _unit;
        if (!isNull _container) then {
            _itemCargo = getItemCargo _container;
            _magazineCargo = getMagazineCargo _container;
            _weaponCargo = getWeaponCargo _container;
            _backpackCargo = getBackpackCargo _container;
        };

        _unit setVariable [
            "42nd_savedBackpackState",
            [_backpackClass, _itemCargo, _magazineCargo, _weaponCargo, _backpackCargo],
            true
        ];
    };
};

if (isNil "para42_fnc_restoreBackpackState") then {
    para42_fnc_restoreBackpackState = {
        params [["_unit", objNull, [objNull]]];
        if (isNull _unit) exitWith {};

        private _savedState = _unit getVariable ["42nd_savedBackpackState", []];
        if (_savedState isEqualTo []) exitWith {};

        _savedState params [
            ["_backpackClass", "", [""]],
            ["_itemCargo", [[], []], [[]]],
            ["_magazineCargo", [[], []], [[]]],
            ["_weaponCargo", [[], []], [[]]],
            ["_backpackCargo", [[], []], [[]]]
        ];

        removeBackpackGlobal _unit;

        if (_backpackClass != "") then {
            _unit addBackpackGlobal _backpackClass;

            private _container = backpackContainer _unit;
            if (!isNull _container) then {
                _itemCargo params [["_itemClasses", [], [[]]], ["_itemCounts", [], [[]]]];
                for "_i" from 0 to ((count _itemClasses) - 1) do {
                    _container addItemCargoGlobal [_itemClasses select _i, _itemCounts select _i];
                };

                _magazineCargo params [["_magClasses", [], [[]]], ["_magCounts", [], [[]]]];
                for "_i" from 0 to ((count _magClasses) - 1) do {
                    _container addMagazineCargoGlobal [_magClasses select _i, _magCounts select _i];
                };

                _weaponCargo params [["_weaponClasses", [], [[]]], ["_weaponCounts", [], [[]]]];
                for "_i" from 0 to ((count _weaponClasses) - 1) do {
                    _container addWeaponCargoGlobal [_weaponClasses select _i, _weaponCounts select _i];
                };

                _backpackCargo params [["_nestedClasses", [], [[]]], ["_nestedCounts", [], [[]]]];
                for "_i" from 0 to ((count _nestedClasses) - 1) do {
                    _container addBackpackCargoGlobal [_nestedClasses select _i, _nestedCounts select _i];
                };
            };
        };

        _unit setVariable ["42nd_savedBackpackState", nil, true];
        _unit setVariable ["42nd_parachuteRestorePending", false, true];
    };
};

if (isNil "para42_fnc_handleParachuteRestore") then {
    para42_fnc_handleParachuteRestore = {
        params [["_unit", objNull, [objNull]]];
        if (isNull _unit) exitWith {};

        [_unit] spawn {
            params ["_unit"];

            waitUntil {
                sleep 0.5;
                !alive _unit ||
                {isTouchingGround _unit} ||
                {(vehicle _unit != _unit) && {isTouchingGround (vehicle _unit)}} ||
                {(getPosATL _unit select 2) < 1}
            };

            if (!alive _unit) exitWith {
                _unit setVariable ["42nd_parachuteRestorePending", false, true];
            };

            sleep 1;
            [_unit] call para42_fnc_restoreBackpackState;
        };
    };
};

if (isNil "para42_fnc_prepareParachuteJump") then {
    para42_fnc_prepareParachuteJump = {
        params [["_unit", objNull, [objNull]]];
        if (isNull _unit || {!alive _unit}) exitWith {};
        if (_unit getVariable ["42nd_parachuteRestorePending", false]) exitWith {};

        [_unit] call para42_fnc_storeBackpackState;
        _unit setVariable ["42nd_parachuteRestorePending", true, true];

        removeBackpackGlobal _unit;
        _unit addBackpackGlobal "ls_gar_hawkbat_backpack";

        [_unit] call para42_fnc_handleParachuteRestore;
    };
};

if (isNil "para42_fnc_laatColumnDrop") then {
    para42_fnc_laatColumnDrop = {
        params [["_vehicle", objNull, [objNull]], ["_caller", objNull, [objNull]]];

        if (!isServer) exitWith {
            [_vehicle, _caller] remoteExecCall ["para42_fnc_laatColumnDrop", 2];
        };

        if (isNull _vehicle || {isNull _caller}) exitWith {};
        if (_vehicle getVariable ["42nd_laatDropInProgress", false]) exitWith {
            [_caller, "Column airdrop is already in progress."] call para42_fnc_laatNotify;
        };

        private _cargoPassengers = (fullCrew [_vehicle, "cargo", false]) apply { _x select 0 };
        _cargoPassengers = _cargoPassengers select { !isNull _x && {alive _x} };

        if (_cargoPassengers isEqualTo []) exitWith {
            [_caller, "There are no cargo passengers to airdrop."] call para42_fnc_laatNotify;
        };

        _vehicle setVariable ["42nd_laatDropInProgress", true, true];

        [_vehicle, _caller, _cargoPassengers] spawn {
            params ["_vehicle", "_caller", "_cargoPassengers"];

            {
                [_x] call para42_fnc_prepareParachuteJump;
                unassignVehicle _x;
                moveOut _x;

                if ((_forEachIndex + 1) < count _cargoPassengers) then {
                    sleep 0.5;
                };
            } forEach _cargoPassengers;

            _vehicle setVariable ["42nd_laatDropInProgress", false, true];
            [_caller, format ["Airdropped %1 passenger(s).", count _cargoPassengers]] call para42_fnc_laatNotify;
        };
    };
};

if (!hasInterface) exitWith {};
if (_laat getVariable ["42nd_laatActionsAdded", false]) exitWith {};

_laat setVariable ["42nd_laatActionsAdded", true];
_laat setVariable ["42nd_laatDropInProgress", _laat getVariable ["42nd_laatDropInProgress", false], true];

_laat addAction [
    "<t color='#9fd3ff'>Column Airdrop Passengers</t>",
    {
        params ["_target", "_caller"];
        [_target, _caller] remoteExecCall ["para42_fnc_laatColumnDrop", 2];
    },
    nil,
    1.5,
    true,
    true,
    "",
    "alive _target && alive _this && vehicle _this isEqualTo _target && driver _target isEqualTo _this && !(_target getVariable ['42nd_laatDropInProgress', false]) && count (fullCrew [_target, 'cargo', false]) > 0"
];
